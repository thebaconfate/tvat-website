---
import "./layout.css";
import Navigation from "@/components/shared/Navigation.astro";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="author" content="Gérard Lichtert" />
    <meta name="description" content="Website van de studentenkring 't VAT" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <Navigation />
    </header>
    <slot />
    <footer></footer>
  </body>
</html>
<style is:global>
  * {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }
  svg {
    width: 100%;
    height: auto;
  }
</style>
