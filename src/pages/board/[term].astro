---
import { terms } from "@/generated/terms";
import Layout from "../../layouts/Layout.astro";
import BoardPage from "@/components/web/board/BoardPage.astro";
import { BoardYear } from "@/lib/board/board-year";
import { getEntry } from "astro:content";
import { getCollection } from "astro:content";

const { term } = Astro.params;
if (!term) return Astro.redirect("/404");
const termIndex = terms.findIndex((a) => a === term);
const nextTerm: string | undefined = terms[termIndex - 1];
const previousTerm: string | undefined = terms[termIndex + 1];
const boardYearCollection = await getCollection("boardYears");
console.log(boardYearCollection);
const boardYearEntry = await getEntry("boardYears", term);
const title = "Bestuur";
---

<Layout title={title}>
  {
    boardYearEntry && (
      <BoardPage
        boardYear={new BoardYear(boardYearEntry.data)}
        nextTerm={nextTerm}
        previousTerm={previousTerm}
      />
    )
  }
</Layout>
