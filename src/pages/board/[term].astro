---
import Layout from "../../layouts/Layout.astro";
import BoardPage from "@/components/web/board/BoardPage.astro";
import { BoardYear, sortByTerm } from "@/lib/board/board-year";
import { getEntry } from "astro:content";
import { getCollection } from "astro:content";

const { term } = Astro.params;
if (!term) return Astro.redirect("/404");
const boardYearCollection = await getCollection("boardYears");
boardYearCollection.sort((a, b) => sortByTerm(a.data.term, b.data.term));
const termIndex = boardYearCollection.findIndex((a) => a.data.term === term);
const nextTerm: string | undefined =
  boardYearCollection[termIndex - 1]?.data.term;
const previousTerm: string | undefined =
  boardYearCollection[termIndex + 1]?.data.term;
const boardYearEntry = await getEntry("boardYears", term);
if (!boardYearEntry) return Astro.redirect("/404");
const title = "Bestuur";
---

<Layout title={title}>
  <BoardPage
    boardYear={new BoardYear(boardYearEntry.data)}
    nextTerm={nextTerm}
    previousTerm={previousTerm}
  />
</Layout>
