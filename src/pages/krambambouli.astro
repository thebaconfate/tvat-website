---
import Layout from "@/layouts/Layout.astro";
import KrambambouliPage from "@/components/web/KrambambouliPage.astro";
import { krambambouliService } from "@/lib/services/krambambouli";
import type {
  DeliveryZoneData,
  KrambambouliProductData,
  PickupLocationData,
} from "@/lib/domain/krambambouli";

const title = "Krambambouli";

const [
  formActivePromise,
  productsPromise,
  pickupLocationsPromise,
  deliveryLocationsPromise,
] = [
  krambambouliService.formActive(),
  krambambouliService.getKrambambouliProducts(),
  krambambouliService.getPickupLocations(),
  krambambouliService.getDeliveryLocations(),
];

let formActive, errors;
let products: KrambambouliProductData[] | null,
  pickupLocations: PickupLocationData[] | null,
  deliveryLocations: DeliveryZoneData[] | null;
try {
  formActive = await formActivePromise;
  if (formActive) {
    [products, pickupLocations, deliveryLocations] = await Promise.all([
      productsPromise,
      pickupLocationsPromise,
      deliveryLocationsPromise,
    ]);
  } else {
    // Empty arrays have to be created otherwise you use the reference to the same
    // array => unexpected behavior
    [products, pickupLocations, deliveryLocations] = Array.from(
      { length: 3 },
      () => [],
    );
  }
  deliveryLocations?.sort((loc1, loc2) =>
    loc1.price.euros === loc2.price.euros
      ? loc1.price.cents - loc2.price.cents
      : loc1.price.euros - loc2.price.euros,
  );
} catch (e) {
  errors = e;
  [products, pickupLocations, deliveryLocations] = Array.from(
    { length: 3 },
    () => [],
  );
  console.log(e);
}
---

<Layout title={title}>
  <KrambambouliPage
    errors={errors}
    formActive={formActive || false}
    products={products}
    pickupLocations={deliveryLocations}
    deliveryLocations={deliveryLocations}
  />
</Layout>
