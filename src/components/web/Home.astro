---
import SaintVeCountdown from "../saint-ve-countdown/SaintVeCountdown";
import Monogram from "@/svgs/Monogram.astro";
import style from "./Home.module.css";
import { activityService } from "@/lib/services/activities";
import { getLocale } from "@/lib/utils";
import Activity from "@/components/web/Activity.tsx";

const activities = await activityService.fetchActivityPage(
  new URLSearchParams([
    ["dateAfter", new Date().toJSON()],
    ["size", String(4)],
  ]),
);
console.log(activities);
const locale = getLocale(Astro.request);
---

<main>
  <div class={style.introBanner}>
    <div>
      <div class={style.monogramContainer}>
        <Monogram />
      </div>
    </div>
    <div class={style.introText}>
      <h1>'t VAT</h1>
      <h2>Pro ambiantia et joewissantia</h2>
    </div>
  </div>
  <div class={style.homepageContentContainer}>
    <div class={style.content}>
      <h2>Activiteiten</h2>
      <ul class={style.activityList}>
        {
          activities.content.map((a) => (
            <Activity activity={a} locale={locale} />
          ))
        }
      </ul>
    </div>
    <div class={style.content}>
      <h2>Saint-Vé</h2>
      <div>
        <SaintVeCountdown client:idle />
      </div>
    </div>
  </div>
</main>
