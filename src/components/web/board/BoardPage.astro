---
import { compareBoardRoles } from "@/lib/board/board-role";
import { BoardYear } from "@/lib/board/board-year";
import BoardMemberItem from "./BoardMemberItem.astro";
import styles from "./BoardPage.module.css";

interface Props {
  boardYear: BoardYear;
  previousTerm?: string;
  nextTerm?: string;
}
const { boardYear, nextTerm, previousTerm } = Astro.props;
boardYear.boardMembers.sort((a, b) => {
  const r = compareBoardRoles(a.boardRole, b.boardRole);
  if (r === 0) return a.name.localeCompare(b.name);
  else return r;
});
const isLastTerm = !previousTerm;
const isFirstTerm = !nextTerm;
const navigatinContainerStyle = isFirstTerm
  ? styles.flexEnd
  : isLastTerm
    ? styles.flexStart
    : styles.spaceBetween;

const boardSize = boardYear.boardMembers.length;
---

<main>
  <h1 class={styles.term}>{`Bestuursjaar ${boardYear.term}`}</h1>
  <div
    class=`${styles.boardyearsNavigationContainer} ${navigatinContainerStyle}`
  >
    {
      !isFirstTerm && (
        <a class={styles.boardyearsNavigation} href={nextTerm}>
          <span class={`${styles.arrow} ${styles.previous}`}>{nextTerm}</span>
        </a>
      )
    }
    {
      !isLastTerm && (
        <a class={styles.boardyearsNavigation} href={previousTerm}>
          <span class={`${styles.arrow} ${styles.next}`}>{previousTerm}</span>
        </a>
      )
    }
  </div>
  <div
    class={`${styles.boardContainer} ${boardSize === 1 ? styles.single : styles.multiple}`}
  >
    {
      boardYear.boardMembers.map((m, index) => (
        <BoardMemberItem boardMember={m} term={boardYear.term} index={index} />
      ))
    }
  </div>
</main>
