.formContainer {
  display: grid;
  justify-content: center;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.inputContainer {
  position: relative;
  display: flex;
  align-items: center;
  border: solid red 1px;
  border-radius: 0.75rem;
  padding: 0.5rem 1rem;
}

.inputContainer > input {
  border: transparent;
  display: flex;
  font-size: 1rem;
}

.inputContainer > input:focus {
  outline: none;
}

.inputIcon {
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: transparent;
}

.inputIcon button {
  cursor: pointer;
}
